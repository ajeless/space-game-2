{
  "name": "burn-vector",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Burn Vector — a turn-based tactical starship-combat duel with a pure shared resolver and SSD-centric interface.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "check": "npm run typecheck && npm run test",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "start:server": "node dist/server/server/index.js",
    "test:browser:smoke": "npm run build && playwright test",
    "test:coverage": "vitest run --coverage",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "fast-check": "^4.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vite": "^7.1.0",
    "vitest": "^3.2.4"
  }
}
